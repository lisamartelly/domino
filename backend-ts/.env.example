# Database (Railway injects this automatically when you link the Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5433/domino?schema=public"

# JWT Authentication
JWT_SECRET_KEY="generate-a-real-secret-with-openssl-rand-hex-32"
JWT_ISSUER="Domino.Backend"
JWT_AUDIENCE="Domino.Frontend"
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS (not needed if serving frontend from the same origin)
# CORS_ORIGIN="https://your-domain.up.railway.app"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="https://your-domain.up.railway.app/events/payment-success"
STRIPE_CANCEL_URL="https://your-domain.up.railway.app/events/payment-cancel"
